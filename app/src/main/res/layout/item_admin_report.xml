<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardReport"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/imgThumbnail"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:background="@drawable/image_background"
            android:visibility="gone"
            android:contentDescription="Report thumbnail" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Header: Type & Severity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/txtEmergencyType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Emergency Type"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1F2A44" />

                <TextView
                    android:id="@+id/txtSeverity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:background="#FFCDD2"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description..."
                android:textSize="13sp"
                android:textColor="#424242"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="6dp" />

            <!-- Location -->
            <TextView
                android:id="@+id/txtLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Location"
                android:textSize="12sp"
                android:textColor="#616161"
                android:layout_marginBottom="6dp" />

            <!-- Time & Action -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtTimeAgo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="5 min ago"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to respond →"
                    android:textSize="12sp"
                    android:textColor="#2196F3"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Panic Alert Indicator -->
        <ImageView
            android:id="@+id/panicIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_dialog_alert"
            android:tint="#F44336"
            android:visibility="gone"
            android:layout_marginStart="8dp"
            android:contentDescription="Panic alert" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
