<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_medical_logo"
            android:contentDescription="@string/logo_description" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1F2A44"
            android:layout_marginTop="16dp" />

        <!-- Role Selection - Moved to Top -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Your Role:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1F2A44"
            android:layout_marginTop="24dp"
            android:layout_gravity="start" />

        <RadioGroup
            android:id="@+id/radioGroupRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioRoleUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Students (Report Emergencies)"
                android:textSize="15sp"
                android:checked="true"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radioRoleMedicalOfficer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👨‍⚕️ Medical Officer"
                android:textSize="15sp"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radioRoleStaff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👥 Staff"
                android:textSize="15sp"
                android:padding="8dp" />

        </RadioGroup>

        <!-- Full Name -->
        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:hint="Full Name"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:inputType="textPersonName"
            android:autofillHints="name" />

        <!-- Registration Number (Optional) - For Users Only -->
        <EditText
            android:id="@+id/etRegNo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="Registration No. (Optional)"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:inputType="text"
            android:visibility="visible" />

        <!-- Contact Number - Phone for Students, PF for Medical Officer/Staff -->
        <EditText
            android:id="@+id/etPFNo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="Phone Number (e.g., +254712345678)"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:inputType="phone"
            android:autofillHints="phone" />

        <!-- Course - For Users Only -->
        <EditText
            android:id="@+id/etCourse"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="Course/Department (e.g., Computer Science)"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:inputType="text"
            android:autofillHints="name"
            android:visibility="visible" />

        <!-- Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_email"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress" />

        <!-- Password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_password"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:drawableStart="@drawable/ic_lock"
            android:drawablePadding="12dp" />

        <!-- Register Button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/create_account"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_login_bg" />

        <!-- Back to Login -->
        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_to_login"
            android:textColor="#1976D2"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
